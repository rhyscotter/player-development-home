<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Player Evaluation</title>
<style>
:root{
  --bg:#000; --card:#111; --border:#1e1e1e; --text:#fff; --muted:#8a8a8a;
  --accent:#7B2EFF; --accent2:#B266FF;
  --clubGlow: rgba(123,46,255,.18);
}
*{box-sizing:border-box}
body{margin:0;background:transparent;color:var(--text);font-family:Arial,sans-serif}
.stage{
  min-height:100vh;padding:22px;
  background:
    radial-gradient(1000px 600px at 20% -10%, rgba(255,255,255,.05), transparent 60%),
    linear-gradient(180deg,#000 0%,#050505 100%);
  position:relative;overflow:hidden;
}
.stage::before{
  content:"";position:absolute;inset:-40% -20%;transform:rotate(-14deg);
  background:linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.05), rgba(255,255,255,0));
  opacity:.18;pointer-events:none;
}
.wrap{max-width:980px;margin:0 auto;position:relative;z-index:2}
.teamName{
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  font-size:44px;text-transform:uppercase;letter-spacing:1px;line-height:1
}
.sub{margin-top:8px;color:var(--muted);font-size:14px}
.themeLine{
  margin-top:14px;height:4px;border-radius:999px;
  background:linear-gradient(90deg,var(--accent),var(--accent2),transparent);
  box-shadow:0 0 18px color-mix(in srgb, var(--accent) 35%, transparent);
  position:relative;overflow:hidden;
}
.themeLine::before{
  content:"";position:absolute;inset:0;
  background:linear-gradient(120deg, rgba(255,255,255,0), rgba(255,255,255,.35), rgba(255,255,255,0));
  transform:translateX(-70%);animation:sweep 2.8s linear infinite;opacity:.9;pointer-events:none;
}
@keyframes sweep{0%{transform:translateX(-70%)}100%{transform:translateX(70%)}}

.card{
  margin-top:18px;background:rgba(17,17,17,.85);
  border:1px solid rgba(255,255,255,.10);
  border-radius:16px;padding:16px;position:relative;overflow:hidden;
  box-shadow:0 20px 70px rgba(0,0,0,.58);
}
.card::before{
  content:"";position:absolute;inset:-50% -20%;transform:rotate(-12deg);
  background:linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.05), rgba(255,255,255,0));
  opacity:.28;pointer-events:none;
}

.hRow{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;position:relative;z-index:2}
.hTitle{
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  font-size:22px;text-transform:uppercase;letter-spacing:.8px;margin:0
}
.pill{
  font-size:11px;font-weight:900;letter-spacing:.8px;text-transform:uppercase;
  padding:7px 10px;border-radius:999px;
  border:1px solid rgba(255,255,255,.14);
  background:rgba(255,255,255,.04);
  color:rgba(255,255,255,.86);
  white-space:nowrap
}
.pill.accent{
  border-color:color-mix(in srgb, var(--accent) 60%, transparent);
  background:color-mix(in srgb, var(--accent) 18%, transparent)
}
.meta{
  margin-top:10px;color:rgba(255,255,255,.72);font-size:13px;line-height:1.45;
  position:relative;z-index:2
}
.smallLine{
  height:3px;border-radius:999px;margin-top:14px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  opacity:.8;position:relative;z-index:2
}

.grid{
  margin-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:12px;position:relative;z-index:2
}
@media (max-width:860px){.grid{grid-template-columns:1fr}}

.infoCard{
  border:1px solid rgba(255,255,255,.10);
  background:rgba(0,0,0,.18);
  border-radius:14px;padding:12px;
}
.infoTitle{
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  font-size:18px;text-transform:uppercase;letter-spacing:.6px;margin:0;color:#fff
}
.infoText{margin-top:8px;color:rgba(255,255,255,.68);font-size:13px;line-height:1.45}

.formSlot{
  margin-top:14px;
  border:1px dashed rgba(255,255,255,.20);
  background:rgba(0,0,0,.18);
  border-radius:16px;
  position:relative;overflow:hidden;
  min-height:680px;
}
.formSlot::after{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(650px 180px at 20% 10%, var(--clubGlow), transparent 60%);
  opacity:.55;
}
.formSlotHeader{
  display:flex;justify-content:space-between;gap:12px;align-items:center;
  padding:12px 14px;border-bottom:1px solid rgba(255,255,255,.10);
  position:relative;z-index:2
}
.formSlotTitle{
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  font-size:18px;text-transform:uppercase;letter-spacing:.6px;margin:0
}
.formSlotBody{
  padding:14px;position:relative;z-index:2
}
.embedArea{
  margin-top:12px;
  border:1px solid rgba(255,255,255,.10);
  background:rgba(0,0,0,.14);
  border-radius:14px;
  overflow:hidden;
  min-height:520px;
}

iframe.formFrame{
  width:100%;
  height:720px;
  border:0;
  display:block;
  background:transparent;
}

.helper{
  margin-top:12px;color:rgba(255,255,255,.62);
  font-size:12px;line-height:1.35;position:relative;z-index:2
}
</style>
</head>

<body>
<div class="stage">
  <div class="wrap">
    <div class="teamName" id="teamName">Player Evaluation</div>
    <div class="sub" id="sub">Complete the evaluation below — a copy is sent to the email entered.</div>
    <div class="themeLine" aria-hidden="true"></div>

    <div class="card">
      <div class="hRow">
        <h3 class="hTitle">Evaluation Form</h3>
        <div class="pill accent" id="statusPill">Ready</div>
      </div>

      <div class="meta" id="scopeMeta">
        Use this form to capture match/training feedback, technical notes, and development priorities.
      </div>

      <div class="grid">
        <div class="infoCard">
          <h4 class="infoTitle">What to include</h4>
          <div class="infoText">
            Clear ratings, specific examples, and 1–2 actionable points the player can work on this week.
          </div>
        </div>
        <div class="infoCard">
          <h4 class="infoTitle">Delivery</h4>
          <div class="infoText">
            The submission is sent to the email address entered in the form. Double-check spelling before submitting.
          </div>
        </div>
      </div>

      <div class="smallLine"></div>

      <div class="formSlot" id="formSlot">
        <div class="formSlotHeader">
          <h4 class="formSlotTitle">Form</h4>
          <div class="pill"></div>
        </div>

        <div class="formSlotBody">
          <div class="embedArea" id="embedArea"></div>
          <div class="helper"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
const CLUB_THEMES = {
  default: { accent:"#7B2EFF", accent2:"#B266FF", bgGlow:"rgba(123,46,255,.18)" },
  cherrybrook: { accent:"#C8102E", accent2:"#FF4B5C", bgGlow:"rgba(200,16,46,.20)" },
  rumson: { accent:"#FFFFFF", accent2:"#BDBDBD", bgGlow:"rgba(255,255,255,.10)" },
  monmouth: { accent:"#00E5FF", accent2:"#00A3FF", bgGlow:"rgba(0,229,255,.18)" }
};

function clean(v){ return String(v || "").trim(); }

function applyTheme({ clubSlug, accent, accent2, glow, source }) {
  const slug = String(clubSlug || "default").trim().toLowerCase();
  const fallback = CLUB_THEMES[slug] || CLUB_THEMES.default;

  const finalAccent  = String(accent || "").trim()  || fallback.accent;
  const finalAccent2 = String(accent2 || "").trim() || fallback.accent2 || finalAccent;
  const finalGlow    = String(glow || "").trim()    || fallback.bgGlow;

  const r = document.documentElement.style;
  r.setProperty("--accent", finalAccent);
  r.setProperty("--accent2", finalAccent2);
  r.setProperty("--clubGlow", finalGlow);

  console.log("🎨 THEME APPLIED:", { slug, accent: finalAccent, accent2: finalAccent2, glow: finalGlow, source: source || "unknown" });
}

(function bootFromHash(){
  const raw = (location.hash || "").replace(/^#/, "");
  const params = new URLSearchParams(raw);
  const clubSlug = params.get("clubSlug") || "default";
  const accent = params.get("accent") || "";
  const accent2 = params.get("accent2") || "";
  const glow = params.get("glow") || "";
  applyTheme({ clubSlug, accent, accent2, glow, source: "hash" });
})();

window.addEventListener("message", (ev) => {
  const data = ev.data;
  if (!data) return;

  if (data.type === "PLAYER_EVAL_INIT") {
    const clubSlug = data.clubSlug || "default";
    const accent = data.theme?.accent || "";
    const accent2 = data.theme?.accent2 || "";
    const glow = data.theme?.glow || "";
    applyTheme({ clubSlug, accent, accent2, glow, source: "postMessage" });

    const coachName = clean(data.coachName || "");
    const teamName = clean(data.title || "Player Evaluation");
    if (teamName) document.getElementById("teamName").textContent = teamName;
    if (coachName) document.getElementById("sub").textContent = coachName;

    return;
  }
});

try { window.parent.postMessage({ type:"IFRAME_READY" }, "*"); } catch(_) {}
</script>
</body>
</html>
